{
  "manifest_version": 3,
  "name": "Kanshape Onshape Bridge",
  "version": "1.0",

  "permissions": [
    "cookies", "storage"
  ],

  "host_permissions": [
    "https://*.onshape.com/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["content_fetch.js"],
      "matches": ["https://*.onshape.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.onshape.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}